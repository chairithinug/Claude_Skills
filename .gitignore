# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Local junk drawer (created when bash sandbox can't unlink stale files —
# delete from Finder when convenient)
_trash/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.python-version

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs and temp
*.log
tmp/
temp/

# Secrets — non-negotiable per CLAUDE.md and STANDARDS.md §12
.env
.env.*
*.env
secrets.*
*.key
*.pem
config.local.*

# Build/test artifacts (NOT .skill files — those ARE the distributable build
# artifacts and should be committed)
dist/
build/
coverage/
.pytest_cache/
.mypy_cache/

# Trigger-eval loop raw outputs (HTML reports, JSON dumps, candidate descriptions).
# Per-skill summary lives in <skill>/evals/loop-results.md and IS committed.
# Raw outputs are large and reproducible from the eval set, so they don't track.
*/evals/loops/

# OS-specific
Thumbs.db
Desktop.ini

graphify-out/manifest.json    # mtime-based, breaks after git clone
graphify-out/cost.json        # local only
# graphify-out/cache/         # optional: commit for speed, skip to keep repo small

# graphify-out — knowledge graph build artifacts.
# Commit the readable outputs (GRAPH_REPORT.md, graph.{html,json}, cost.json).
# Ignore manifest + chunk lists + cache: they embed absolute /Users/... paths
# that leak on public GitHub, and are reproducible from a fresh graphify run.
graphify-out/manifest.json
graphify-out/.chunk*_files.txt
graphify-out/.graphify_python
graphify-out/.graphify_uncached.txt
graphify-out/cache/
